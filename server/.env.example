# Copy this file to .env and fill in the values.
# (.env is gitignored and never committed.)

# Port the API listens on
PORT=5000

# MongoDB connection string (free tier: https://www.mongodb.com/atlas)
MONGO_URI=

# Free Gemini API key for the AI assistant (https://aistudio.google.com/ → "Get API key")
GEMINI_API_KEY=

# Secret for signing login tokens — any long random string
JWT_SECRET=

# Frontend URL (used for CORS and email links). For local dev leave as-is.
CLIENT_URL=http://localhost:3000

# OPTIONAL — to email appointment confirmations (Gmail app password).
# Leave blank to skip emails; the in-app calendar reminder still works.
EMAIL_USER=
EMAIL_PASS=
